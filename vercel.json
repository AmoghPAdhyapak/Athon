{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "BASE_PATH=/ PORT=3000 NODE_ENV=production pnpm --filter @workspace/caption-generator run build",
  "outputDirectory": "artifacts/caption-generator/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
